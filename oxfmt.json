{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "sortImports": true,
  "sortPackageJson": {
    "sortScripts": false
  },
  "ignorePatterns": [
    "build/**",
    "**/build/**",
    "dist/**",
    "**/dist/**",
    "node_modules/**",
    "**/node_modules/**",
    ".next/**",
    "**/.next/**",
    "cdk.out/**",
    "**/cdk.out/**"
  ]
}
